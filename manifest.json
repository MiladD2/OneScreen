{
  "manifest_version": 3,
  "name": "OneScreen",
  "version": "1.0",
  "description": "Capture full pages and save as PDF, PNG, or to clipboard.",
  "permissions": [
    "activeTab",
    "scripting",
    "offscreen",
    "storage",
    "alarms",
    "tabs",
    "downloads",
    "contextMenus",
    "nativeMessaging",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "default_locale": "en",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "background": {
    "service_worker": "scripts/serviceWorker.js"
  },
  "commands": {
    "capture-entire-page-action": {
      "description": "Capture entire page"
    },
    "capture-visible-page-action": {
      "description": "Capture visible page"
    }
  }
}
